{
  "name": "pi-return-on",
  "version": "0.1.0",
  "description": "Pi extension for timers, watches, and return-on condition triggers that wake the agent later.",
  "type": "module",
  "private": true,
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "smoke": "tsx test/integration-smoke.ts",
    "scan-errors": "node scripts/scan-return-on-errors.mjs",
    "scan-errors:recent": "node scripts/scan-return-on-errors.mjs --days 7",
    "prune-sessions": "node scripts/prune-old-sessions.mjs",
    "collect:direct-waits": "node scripts/collect-direct-wait-examples.mjs",
    "review:direct-waits": "node scripts/review-direct-wait-examples.mjs",
    "test:direct-wait-tools": "node --test scripts/collect-direct-wait-examples.test.mjs scripts/review-direct-wait-examples.test.mjs test/context-compaction.test.ts",
    "test:collect-direct-waits": "npm run test:direct-wait-tools",
    "test:scan-direct-waits": "node scripts/scan-direct-waits.test.mjs",
    "test": "npm run typecheck && npm run test:direct-wait-tools && npm run test:scan-direct-waits && npm run smoke",
    "audit:direct-waits": "node scripts/scan-direct-waits.mjs"
  },
  "peerDependencies": {
    "pi-forks": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "pi-forks": {
      "optional": true
    }
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
